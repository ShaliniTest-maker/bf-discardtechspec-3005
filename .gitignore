# Node.js Tutorial Server .gitignore
# Educational Express.js project exclusions for clean repository management

# Node.js Dependencies
# Exclude npm packages and Express.js framework dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm

# Environment Configuration
# Exclude environment variables and local configuration files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Runtime and Build Artifacts
# Exclude generated files and temporary build outputs
dist/
build/
*.tsbuildinfo
.nyc_output

# Logs and Debug Files
# Exclude application logs and debugging information
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# Coverage and Testing
# Exclude test coverage reports and temporary test files
coverage/
.coverage
.nyc_output
.cache
*.lcov

# Temporary Files
# Exclude system and application temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Operating System Files
# Cross-platform OS-specific file exclusions

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows system files
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/

# Linux system files
*~
.nfs*

# IDE and Editor Configurations
# Development environment specific configurations

# Visual Studio Code
.vscode/
*.code-workspace

# IntelliJ IDEA / WebStorm
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
.vimrc.local

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Runtime Directories
# Exclude Node.js runtime specific directories
.npm
.eslintcache
.yarn-integrity
.pnp
.pnp.js

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (if used in future)
.cache
.parcel-cache

# ESLint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional stylelint cache
.stylelintcache

# SvelteKit build / generate output (if extended)
.svelte-kit

# Educational Tutorial Specific
# Exclude files that might be created during tutorial exercises
tutorial-notes.txt
test-requests.http
example-output.txt